          "_dirType": "sub",
          "answer": {
            "_dirType": "int",
            "_value": "1"
          }
        },
        "default": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "這次的事情絕對不能就這樣算了.會和丈夫分手的."
          }
        },
