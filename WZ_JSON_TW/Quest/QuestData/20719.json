  "QuestInfo": {
    "_dirType": "sub",
    "name": {
      "_dirType": "string",
      "_value": "[皇家騎士團] 魔法森林派遣任務結束"
    },
    "0": {
      "_dirType": "string",
      "_value": "#m101000000#地區情報員#b#p1103003##k關於任務有話要說…"
    },
    "1": {
      "_dirType": "string",
      "_value": "#p1103003#說關於這件事#p1032001#確定沒有嫌疑，總之這件事到此告一段落，整理暗影相關的報告書交給#b#p1101002##k。"
    },
    "2": {
      "_dirType": "string",
      "_value": "把#t4032144#交給了#p1101002#。#p1101002#說玩偶製作師的勢力逐漸在擴大，若要抵擋玩偶製作師必須變得更強大，因此進行下一任務之前必須努力的修煉。"
    },
    "area": {
