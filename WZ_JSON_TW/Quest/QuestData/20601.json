      },
      "stop": {
        "_dirType": "sub",
        "item": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "還沒有取得#b#t4032120##k嗎？#t4032120#是#m130020000#，只能在#b第三練武場#k裡面獲得。"
          }
        }
