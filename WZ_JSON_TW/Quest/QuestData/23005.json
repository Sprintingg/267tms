    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "你是#h0#…？什麼事情？我正忙著發傳單呢？你是在按照校長的吩咐在幫村民的忙？真的嗎？…那就拜託你一件事情吧。"
      },
      "stop": {
        "_dirType": "sub"
