    "0": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n彼得懷疑在伊甸島和提斯克島上的古代神石像可能是假的。他說的是真的嗎？去問問伊甸島的學者#b歐比恩#k吧。\r\n"
    },
    "1": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n當被問及石像時，歐比恩很為難，說一起去有壁畫的洞窟。去看看伊甸提斯克島的洞穴吧。\r\n"
    },
    "2": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n向歐比恩確認事實後，他說古代神的石像只是憑想像製作的。並說很多古代神的壁畫都被抹去了，所以才做出這不得已的選擇...\r\n"
