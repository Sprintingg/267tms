      }
    },
    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "哦哦！找到#t4032765#了啊！真謝謝！雖然膽小鬼#p2152008#逃跑了，但相信你會幫我到底！"
      },
