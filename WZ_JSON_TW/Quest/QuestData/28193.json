    "0": {
      "_dirType": "string",
      "_value": "#b墮落城市#k的#b#@1052001:##k說他已經完成樣本分析。我們去看看他有什麼發現吧。"
    },
    "1": {
      "_dirType": "string",
      "_value": "病毒是經由水傳播的。我們去找#b墮落城市#k的#b#@9201120:##k談一談。"
