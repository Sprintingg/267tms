        "15": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "我要做什麼呢, 母親?"
          }
        },
        "16": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "…是這樣阿 #b(月妙結束回想了.)#k\\r\\n所以阻擋拜壓歲錢的很多親戚得很重要的任務,這明宮月妙所負責了!"
          }
        },
        "17": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b不管怎麼樣怎麼阻擋來拜的親戚呢? 這太過分了.#k"
