          "npcID": {
            "_dirType": "int",
            "_value": "9001114"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "1"
          }
        },
        "11": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "......打嗝."
          }
        },
        "12": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "問題是 #b壓歲錢#k.一名給  10,000楓幣也… 這樣的話我們家的柱子快要倒了.所以月妙你要幫助我們好不好."
          },
          "npcID": {
            "_dirType": "int",
            "_value": "9001115"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "1"
          }
        },
        "13": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "不要, 好煩."
          }
        },
        "14": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "那我讓他使用你的電腦囉?"
