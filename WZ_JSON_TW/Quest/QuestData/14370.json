        "18": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "保護媽媽爸爸的壓歲錢的話,我會給你 #b#i4310113# #t4310113##k和 #b#i2432529# #t2432529##k.這對你還不錯的提案不是嗎?哈哈哈哈..."
          }
        },
        "19": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b我做甚麼好呢, #p9000274##k?"
