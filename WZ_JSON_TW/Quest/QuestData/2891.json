    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "看來有收集到一些情報了呢。"
      },
      "stop": {
        "_dirType": "sub",
        "npc": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "繼續問我也沒有別的有用情報了。 去找後街吉姆吧。"
