        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "是個心軟的女孩呀。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "咯嗯。不願意問嗎？也跟你認識#p1012108#回答也應該方便。"
