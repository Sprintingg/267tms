{
  "QuestInfo": {
    "_dirType": "sub",
    "name": {
      "_dirType": "string",
      "_value": "[維多利亞島] 證明身為訓練師的能力"
    },
    "parent": {
      "_dirType": "string",
      "_value": "證明身為訓練師的能力"
    },
    "order": {
      "_dirType": "int",
      "_value": "1"
    },
    "0": {
      "_dirType": "string",
      "_value": "聽說，只要向寵物訓練師巴特斯證明自己身為訓練師的能力，就可以得到特殊的能力…"
    },
    "1": {
      "_dirType": "string",
      "_value": "為了證明身為訓練師的能力，必須蒐集藏匿的紙條"
    },
    "2": {
      "_dirType": "string",
      "_value": "終於可以向巴特斯學習帶領多隻寵物的技能了嗎？"
    },
    "area": {
      "_dirType": "int",
      "_value": "30"
    }
  },
  "Act": {
    "_dirType": "sub",
    "0": {
      "_dirType": "sub"
    },
    "1": {
      "_dirType": "sub",
      "nextQuest": {
