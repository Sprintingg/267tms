        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "謝謝你來，精靈遊俠。就如同那因哈特說的一樣，我特別找你來，是因為我想請教你的意見。身為一個種族的王，同時也是和黑魔法師戰鬥的英雄…希望你能幫忙。"
          }
        },
        "1": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b是什麼決定？"
          },
          "userSay": {
            "_dirType": "int",
            "_value": "1"
