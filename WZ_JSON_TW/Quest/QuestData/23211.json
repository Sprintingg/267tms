      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "這說來有點話長。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "難道你還在懷疑我嗎？"
