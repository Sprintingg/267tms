    "name": {
      "_dirType": "string",
      "_value": "[艾比米修斯盒子]令人討厭的伏日!"
    },
    "autoStart": {
      "_dirType": "int",
      "_value": "1"
    },
    "autoComplete": {
      "_dirType": "int",
      "_value": "1"
