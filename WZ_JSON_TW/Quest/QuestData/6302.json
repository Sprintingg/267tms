    "name": {
      "_dirType": "string",
      "_value": "[楓之谷世界的冒險家] 卡勒塔的老舊手鐲"
    },
    "parent": {
      "_dirType": "string",
      "_value": "堅固的意志"
    },
    "order": {
      "_dirType": "int",
      "_value": "3"
    },
    "1": {
      "_dirType": "string",
      "_value": "#p2060100#說道…若想要吸收意志，需要作成藥來服用。但她不願白白地幫忙，而開出條件！她告知可以先去找#b#p2040050##k打探一下，設法幫她拿回她的#b#t4031463##k。"
    },
    "2": {
      "_dirType": "string",
      "_value": "#b#p2040050##k真的知道有關#p2060100#的手鐲的事情嗎？"
    },
    "blocked": {
      "_dirType": "int",
      "_value": "1"
    },
    "area": {
