      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "為了對抗黑魔法師,皇家騎士團和冒險家要合作.以後需要助力的話,再過來找."
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "不需要的話,那就算了,好像不是心甘情願地拒絕皇家騎士團好意呢."
        }
      }
