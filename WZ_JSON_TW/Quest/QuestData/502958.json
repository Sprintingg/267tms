    "0": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n探求者#b彼得#k似乎發現了什麼與伊甸提斯克島的古代神有關的事情。和彼得對話吧。"
    },
    "1": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n彼得說，在伊甸島和提斯克島上的古代神的石像可能是假的，請伊甸島的學者去確認。去#b歐比恩#k那裡確認一下吧。\r\n"
    },
    "2": {
      "_dirType": "string",
      "_value": "#e#r<前往夏季和冬季並存的島嶼！>#k#n\r\n\r\n#e[活動期間]#n\r\n2024年 02月 07日 維護後 ～\r\n2024年 04月 01日 下午 11點 59分為止\r\n\r\n#e[活動內容]#n\r\n聽說伊甸島和提斯克島的石像不是參考古代神的樣貌而製作，只是僅憑想像所製作的。那句話的意思是...？等等進行調查的彼得吧。\r\n"
    },
