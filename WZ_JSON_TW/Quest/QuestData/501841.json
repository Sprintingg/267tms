        },
        "3": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "真的嗎．．？我只是隨便說說而已耶。\\r\\n謝謝你！布萊爾小姐！\\n我就來經營看看吧，我有一間店了！"
          },
          "userSay": {
            "_dirType": "int",
            "_value": "1"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "2"
