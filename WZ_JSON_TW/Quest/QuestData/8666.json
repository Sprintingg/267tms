        }
      }
    },
    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "肚子好餓呀！過年就是要吃年菜呀，小伙子你願意幫我個忙嗎？為我帶來好吃的年菜給我！"
      },
      "stop": {
        "_dirType": "sub"
