    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "我一直拜託人們幫我找我的硬幣，但大家似乎都很忙。他們不肯花時間聽我說。\\n\\n而他們的理由是這裡有太多#r藍水靈#k。你知道我要什麼，對嗎？我要請你幫我一個忙。"
      },
      "stop": {
        "_dirType": "sub"
      },
      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "你先幫我在#b地鐵#k打20隻#r藍水靈#k，我才要給你。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "不願意嗎？好吧，你自己看著辦！"
