    "name": {
      "_dirType": "string",
      "_value": "[納希沙漠] 沙影團的懸賞"
    },
    "parent": {
      "_dirType": "string",
      "_value": "沙漠的懸賞"
    },
    "order": {
      "_dirType": "int",
