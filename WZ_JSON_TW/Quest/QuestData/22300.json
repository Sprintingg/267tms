  "Say": {
    "_dirType": "sub",
    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "龍魔導士，#p1013000#…變得這麼強了…"
      },
      "1": {
        "_dirType": "string",
        "_value": "來我的島上吧…"
      },
      "2": {
        "_dirType": "string",
        "_value": "現在就是遺忘力量繼承的時候…"
      },
      "3": {
        "_dirType": "string",
        "_value": "那人就是你…"
      },
      "stop": {
        "_dirType": "sub"
