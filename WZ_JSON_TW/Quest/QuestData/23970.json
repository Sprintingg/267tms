          "0": {
            "_dirType": "string",
            "_value": "是嗎？那種動物生活在這個礦山？沒看錯嗎？再去看一下。"
          },
          "2": {
            "_dirType": "string",
            "_value": "是嗎？那種動物生活在這個礦山？沒看錯嗎？再去看一下。"
          }
