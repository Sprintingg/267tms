    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "氧氣呼吸器應該在這裡…"
      },
      "1": {
        "_dirType": "string",
        "_value": "#b(吉可穆德從塑膠袋裡拿出一個像用完扔掉的氧氣呼吸器。非常善良的面孔。)#k"
      },
      "2": {
        "_dirType": "string",
        "_value": "對傑奇來說這個就足夠了。不，這個也過分…啊？不衛生？不用擔心。傑奇不會使用這個的。"
      },
      "stop": {
        "_dirType": "sub"
      },
      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "好，反正#b傑奇#k想要這個，趕快給他拿過去吧。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "沒必要擔心…因為我知道傑奇怎樣用這個。"
        }
      }
    },
    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "氧氣呼吸器終於來了！可以鬆口氣了。那麼，快戴上…戴上？！"
      },
      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "#b(按照人的面孔製造的#t4032763#。有娃娃頭的#p2152005#是無法戴上的。#p2152005#好像現在才明白並受到了打擊。熊娃娃的表情顯得非常恍惚…)#k"
        }
      },
