        "2": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "噢噢~冷靜一點!幹嘛這麼老土呢?我所謂的一決勝負並非使用蠻力拿武器戰鬥!而是更加高級,有品味的對決方法!"
          }
        },
        "3": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "是嗎?儘管說說看吧!"
