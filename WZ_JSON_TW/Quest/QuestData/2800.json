        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "冒險家小兄弟啊！雖然你已經成長許多，但目前來說想要靠自己的力量進行戰鬥還是不太夠。一邊學習與人相互配合的方法，同時鍛鍊自我是非常重要的，去勇士之村找義安看看吧！"
          },
          "npcID": {
            "_dirType": "int",
            "_value": "1022000"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "1"
