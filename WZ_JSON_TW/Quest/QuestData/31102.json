        "4": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "就這樣把未來之門敞開是很危險的， 必須關門。 可是連我這個神殿管理人都很難關閉未來之門。 不管怎麼說，好像需要比想象中更強大的力量。"
          }
        },
        "5": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b(不知為何感覺能預想到下一句話…。)#k"
