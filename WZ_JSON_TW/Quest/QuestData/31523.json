        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "您好。 當看到#b#p3001102##k瞬間消滅完幽靈後，他感到非常滿意。"
          },
          "npcID": {
            "_dirType": "int",
