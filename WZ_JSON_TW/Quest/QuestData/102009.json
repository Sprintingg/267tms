        "1": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b雖然拿到了證明傳說的文物，但經過漫長的歲月已經黯然失色。#k"
          },
          "userSay": {
            "_dirType": "int",
            "_value": "1"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "1"
          }
        },
        "2": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b先回去找收藏家比較好，他說會在弓箭手村市場等著，那就去找找看吧。#k\\r\\n#b#e(*接受時會立即移動。)#n#k"
          }
        }
      },
      "stop": {
        "_dirType": "sub"
