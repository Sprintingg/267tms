      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "我依舊在冰原雪域長老的官邸地下。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "我我…要讓我就這樣瘋掉嗎？真的嗎？"
        }
