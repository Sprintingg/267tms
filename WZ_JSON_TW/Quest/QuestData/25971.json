      "sayEx": {
        "_dirType": "sub",
        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "你好，我是鐵匠愛爾森。我們先前可能也見過面，那你應該學過利用卷軸的痕跡將力量注入裝備的方法了吧！我已經調查出使用星星力量讓裝備變得更強的方法了，你要聽聽看嗎？"
          },
          "imgPos": {
            "_dirType": "int",
