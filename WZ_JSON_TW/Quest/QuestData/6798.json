{
  "QuestInfo": {
    "_dirType": "sub",
    "name": {
      "_dirType": "string",
      "_value": "[維多利亞島] 新的武器"
    },
    "area": {
      "_dirType": "int",
      "_value": "30"
    },
    "autoStart": {
      "_dirType": "int",
