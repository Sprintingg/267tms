      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "不用太多，只要20個我就可以重新栽種我的田地了。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "不想幫忙幹嘛問東問西的啊！"
        }
      }
