    "name": {
      "_dirType": "string",
      "_value": "[楓之谷世界的冒險家] 塔塔曼的提議"
    },
    "0": {
      "_dirType": "string",
      "_value": "#b#p2081500##k建議我智取#b#t4031517##k和#b#t4031518##k，先到神木村拜訪#b#p2081000##k。"
    },
    "1": {
      "_dirType": "string",
      "_value": "#b#p2081000##k告訴我如果想要得到#b#t4031517##k和#b#t4031518##k，先得找到#b#t4031348##k。關於祕咒，其他村莊的卷軸商人也許知道...\\r\\n#i4031348##t4031348##k#b#c4031348#/1"
    },
    "2": {
      "_dirType": "string",
      "_value": "帶回#b#t4031348##k並獲得#b#t4031517##k和#b#t4031518##k。"
    },
    "blocked": {
