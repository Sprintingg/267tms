        "5": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "竟然是奢侈品！這樣看來這應該是超－級尖端的技術的集合體吧～？使用松茱麗的心跳脈搏的提升來確認，當跳到最高時就能告白囉。所以我和松茱麗 #e#h0##n正在尋找加快松茱麗心跳數的遊樂器材呢。"
          },
          "npcID": {
            "_dirType": "int",
