        "5": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "嗚哇啊啊，內容開始出來了。這個內容我會傳交給#b#p3001100##k的。請#h0#等到#b#p3001100#k聯絡我為止。"
          },
          "npcID": {
            "_dirType": "int",
