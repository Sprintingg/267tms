    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "找到了！就在這裡…那請你把這粉灑在雞蛋上吧！"
      },
      "yes": {
        "_dirType": "sub",
        "0": {
