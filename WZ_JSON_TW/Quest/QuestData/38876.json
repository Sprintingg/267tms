      "_dirType": "sub",
      "sayEx": {
        "_dirType": "sub",
        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "真的帶來了幽靈死神的鐮刀嗎？"
          }
        },
        "1": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "這般光澤，這般鋒利…！這肯定是最高級的武器啊！絕對可以賣很貴！額嘿嘿！非常感謝！你是我的恩人！#b根本不需要奪回總部的王牌！你就是我的王牌#k！"
          }
