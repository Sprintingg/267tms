      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "謝謝你，冒險者。今後我會遠離村子，獨自懺悔。勇敢的冒險者！請你務必要回到神木村，把我的話轉告給#b村長塔塔曼#k。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "勇敢的冒險者，拜託你……"
        }
      }
