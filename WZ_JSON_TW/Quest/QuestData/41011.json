      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "#b#MDmirrorD_321_0_##k有侏儒怪.去見#b侏儒怪的帝王雷克斯#k.向他傳達和平的意思,#r不管手段和方法,#k讓他在和平協定書簽名並取回."
        }
      },
      "no": {
