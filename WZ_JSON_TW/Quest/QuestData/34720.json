  "Say": {
    "_dirType": "sub",
    "0": {
      "_dirType": "sub",
      "sayEx": {
        "_dirType": "sub",
        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b(雖然有把戴諾德的肋排帶給尤蘭斯老頭，但是不僅被搶走物品，還沒什麼效果。)#k\\r\\n"
