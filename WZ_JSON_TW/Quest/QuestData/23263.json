        "0": {
          "_dirType": "string",
          "_value": "#b#o5120001#, #o5120002#, #o5120003##k有出現在 #b#m200000000#庭園#k. 各帶回 #r尾巴毛#k 30個.\\r\\n"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "你不要這樣。 這對我是很重要的事。 拜託你。"
        }
      }
