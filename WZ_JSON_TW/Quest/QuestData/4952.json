          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "我明白你尚未獲得我造新裝配機需要的每項材料。滴-答，別浪費時間！每秒失去就有另一個孩子沒有玩具！"
          }
        }
      }
