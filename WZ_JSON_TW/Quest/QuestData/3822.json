      "0": {
        "_dirType": "string",
        "_value": "看起來您經常到處旅行.您一定見過很多不同的人吧.您是一個有經驗的冒險者，我想拜託你件事可以嗎?"
      },
      "stop": {
        "_dirType": "sub"
