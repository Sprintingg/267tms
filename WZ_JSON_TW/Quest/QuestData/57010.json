    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "有事拜託您。#h0#說不一定知道，本能寺有叫'靈魂石'神祕的存在。這個石頭有善/惡的力量存在，隨著用途而有所改變。織田好像要用靈魂石策劃著什麼，我猜應該是要用在召喚第六天魔王。從他們那邊取來靈魂石。"
      },
      "stop": {
        "_dirType": "sub"
      },
      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "謝謝。我在等你。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "因為什麼在猶豫呢。"
        }
