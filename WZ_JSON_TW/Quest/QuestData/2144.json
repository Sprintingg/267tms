    "0": {
      "_dirType": "string",
      "_value": "#p1022006#博士是在#m102000000#一帶旅行，並進行研究工作的考古專家。聽說他最近聽到一些奇怪的謠言，於是要求和我見個面。"
    },
    "1": {
      "_dirType": "string",
      "_value": "#p1022006#博士在發掘過程中，聽說在#m102000000#地區存活著一種從遠古時期就存在的樹種，但到底是何種樹木及生長在哪裡都全都不清楚，於是希望我去#b#m102000000#搜集有關該樹種的情報。#k\\n\\n#y2148##b(#u2148#)#k\\n#y2149##b(#u2149#)#k\\n#y2150##b(#u2150#)#k\\n#y2151##b(#u2151#)#k\\n#y2152##b(#u2152#)#k"
    },
    "2": {
      "_dirType": "string",
      "_value": "向#p1022006#博士講述了#m102000000#居民所說的內容。莫非#p1020000#所說的#o3220000#就是#p1022006#博士所指那樹種嗎？"
    },
    "area": {
      "_dirType": "int",
      "_value": "49"
