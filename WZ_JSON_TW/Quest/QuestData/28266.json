      "_dirType": "string",
      "_value": "阿司塔洛的祕密"
    },
    "0": {
      "_dirType": "string",
      "_value": "#b奇幻村#k的#b#@1061011:##k說他已經解開這個神祕的徽記了。我們去找他吧。"
    },
    "1": {
      "_dirType": "string",
      "_value": "我們到#b奇幻村#k找#b#@1061011:##k談一談。"
    },
    "2": {
      "_dirType": "string",
      "_value": "你已經從#b奇幻村#k的#b#p1061011##k口中探聽到阿司塔洛的祕密。"
    },
    "area": {
