      "yes": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "聽完旁邊的 #b#p3001001##k說明後，請協助重建奪回本部。拜託你了。"
        }
      },
      "no": {
        "_dirType": "sub",
        "0": {
          "_dirType": "string",
          "_value": "雖然他應該很忙。(帶著冰冷的視線轉頭。)"
