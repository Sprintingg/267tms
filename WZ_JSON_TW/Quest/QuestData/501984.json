        "2": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#i3801666#\\r\\n是呀。不僅如此我還有卓越的財力呢。\\n展現你完美調香的姿態，\\n我將會給予你對應的完美空間。"
          }
        },
        "3": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "請根據性別穿上從皇家風格獲得的\\n魅惑調香師套裝全套再來找我。\\n#r(該活動任務每個伺服器只能執行1次。)\\r\\n#b#e[魅惑調香師套裝]#k\\r\\n#e[帽子]#n#i1005969# #t1005969#(男) #i1005970#   #t1005970#(女) \\r\\n#e[套服]#n#i1050629#   #t1050629#(男) #i1051702#   #t1051702#(女)  \\r\\n#e[鞋子]#n#i1070138#   #t1070138#(男) #i1071154#   #t1071154#(女)  \\r\\n#e[斗篷]#n#i1103425#   #t1103425#\\r\\n#e[武器]#n#i1703184#   #t1703184#"
          }
        }
