    },
    "0": {
      "_dirType": "string",
      "_value": "#p9001102#的月亮照片的碎片會散落在哪裡呢？掌握楓葉世界所有事情的#p9330072#會不會知道？去見見#b#p9330072##k。"
    },
    "1": {
