    },
    "0": {
      "_dirType": "string",
      "_value": "#m310000000#의 교장선생님 #p2152000#가 겨울을 맞이하여 월동준비를 시작했다. 뭔가 도움이 필요한 것 같은데 #b#p2152000##k 을 찾아 #b#m310000000##k로 가보자."
    },
    "1": {
      "_dirType": "string",
      "_value": "#p2152000#는 에델슈타인의 월동준비는 #b#t4031228##k를 모으는 일에서 시작한다고 했다. 블랙윙들이 광산을 장악한 이후로는 구하기 매우 어려워졌지만, 몬스터들에게서도 간간히 구할 수 있다면서 주문들을 위해 #b#t4031228# 20개#k를 모아와 달라고 부탁했다."
    },
    "2": {
