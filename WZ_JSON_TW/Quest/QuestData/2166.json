    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "噢…剛才我感覺到發光石的力量了。怎麼樣？是不是全身充滿了力量？？"
      },
      "stop": {
        "_dirType": "sub",
        "npc": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "發光石就放在動力室。你還沒找到嗎？"
          }
        },
        "quest": {
          "_dirType": "sub",
