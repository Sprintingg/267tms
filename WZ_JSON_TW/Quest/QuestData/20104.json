  "QuestInfo": {
    "_dirType": "sub",
    "name": {
      "_dirType": "string",
      "_value": "[皇家騎士團] 暗夜行者之路"
    },
    "0": {
      "_dirType": "string",
      "_value": "終於來到選擇的時刻。若要了解黑暗盜賊，暗夜行者，請與#b黑暗騎士團長#p1101006##k對話。"
    },
    "1": {
      "_dirType": "string",
      "_value": "身為與光並存的黑暗─暗夜行者，若要成為皇家騎士團的騎士請選擇#p1101006#。"
    },
    "2": {
      "_dirType": "string",
