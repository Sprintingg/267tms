  "QuestInfo": {
    "_dirType": "sub",
    "name": {
      "_dirType": "string",
      "_value": "[童話村] 消滅鬼怪的準備"
    },
    "parent": {
      "_dirType": "string",
      "_value": "烏山鬼怪"
    },
    "order": {
      "_dirType": "int",
