    "1": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "嗯？什麼事情？啊？你想要讀取記事本中所隱藏的部分？讓我先來看一下你所說的記事本是什麼…"
      },
      "stop": {
        "_dirType": "sub",
