    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "這一切都得怪我。嗚嗚…我不該放牠自己…你願意聽我說嗎？"
      },
      "stop": {
        "_dirType": "sub"
