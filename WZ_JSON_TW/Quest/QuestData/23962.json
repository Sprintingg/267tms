    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "看場所和服裝，登記…不，只看臉也知道。你是#h0#。好像非常清閒。所以交給私人任務。"
      },
      "stop": {
        "_dirType": "sub"
