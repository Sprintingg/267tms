          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "還沒去#m130000000#嗎？快去#m130000000#交那個信封吧。不知道黑色翅膀哪個時候攻擊那裡啊。"
          }
        },
        "item": {
          "_dirType": "sub",
