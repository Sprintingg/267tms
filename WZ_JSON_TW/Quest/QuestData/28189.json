    },
    "1": {
      "_dirType": "string",
      "_value": "#b弓箭手村#k的#b#@1012003:##k想製作感冒藥，想請你尋找一些材料。\\n\\n#r菇菇寶貝傘#k(從#r菇菇寶貝#k身上掉落)\\n#r蝴蝶結#k(從#r緞帶肥肥#k身上掉落)\\n#r綠水靈珠#k(從#r綠水靈#k身上掉落)\\n\\n我們返回#b弓箭手村#k向#b#@1012003:##k回報。"
    },
    "2": {
