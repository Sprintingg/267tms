        "npc": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "麥吉哥對徒弟最後一次來消息得是進入 #b奇幻村 地下地下城#k想要持續調查得前言.所以在哪開始會不會比較好? 請一定尋找武英."
          }
        }
      }
    }
