          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "還沒去找#b#p2152018##k？找到20個#k#b#t4032768#，就交給#p2152018#吧。那個人，雖然對機器人不懂，但肯定跟熟悉的聯繫著。"
          }
        },
