    "name": {
      "_dirType": "string",
      "_value": "[組隊任務] 巨居蟹的祭品"
    },
    "parent": {
      "_dirType": "string",
      "_value": "打倒巨居蟹！"
    },
    "order": {
      "_dirType": "int",
