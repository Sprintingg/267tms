    "0": {
      "_dirType": "sub",
      "sayEx": {
        "_dirType": "sub",
        "0": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "#b#h0##k知道蘊含著月光的「月露」嗎？那在納希綠洲城是很稀有的東西。據說納希綠洲城的砂兔身上會有。"
          }
        },
        "1": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "可是你知道吧？布萊爾我啊，是個懷抱著遠大夢想的人。比起蘊含著月光的小小露珠，我更渴望找到廣大的綠洲！！"
          }
        },
        "2": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "布萊爾我啊，果然是個有雄心壯志的人。呵呵。"
          }
        },
        "3": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "你打算怎麼找呢？"
          },
          "userSay": {
            "_dirType": "int",
            "_value": "1"
          },
          "imgPos": {
            "_dirType": "int",
            "_value": "2"
          }
        },
        "4": {
          "_dirType": "sub",
          "msg": {
            "_dirType": "string",
            "_value": "我想到的方法是，#b#h0##k和砂兔一起組成綠洲勘查隊去搜尋綠洲！\\n\\n怎麼樣？這個計畫很棒吧？"
          }
        },
        "5": {
          "_dirType": "sub",
