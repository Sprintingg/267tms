        "npc": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "把克里夫哥哥所賣的 #b高級手帕#k交給 帕馬爾就可以。"
          }
        },
        "item": {
          "_dirType": "sub",
          "0": {
            "_dirType": "string",
            "_value": "有什麼事呢?不管你怎麼拜託,我都無法讓你跟公主見面.請你走吧."
