    "0": {
      "_dirType": "sub",
      "0": {
        "_dirType": "string",
        "_value": "沒錯，那個塗鴉是我住在城寨時畫下我過去王族時期的畫。沒想到居然留到現在…\\r\\n"
      },
      "1": {
        "_dirType": "string",
